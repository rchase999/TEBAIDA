# ──────────────────────────────────────────────
# DebateForge — Environment Configuration
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values
# All API keys are optional — only needed for the providers you want to use

# ── AI Provider API Keys ──
# Get your key at https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=

# Get your key at https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=

# Get your key at https://aistudio.google.com/app/apikey
VITE_GOOGLE_API_KEY=

# Get your key at https://console.mistral.ai/api-keys
VITE_MISTRAL_API_KEY=

# Get your key at https://console.groq.com/keys
VITE_GROQ_API_KEY=

# ── Local Model Endpoints ──
# Ollama (default: http://localhost:11434)
VITE_OLLAMA_ENDPOINT=http://localhost:11434

# LM Studio (default: http://localhost:1234/v1)
VITE_LMSTUDIO_ENDPOINT=http://localhost:1234/v1

# ── App Configuration ──
# Default theme: light | dark | system
VITE_DEFAULT_THEME=system

# Enable debug logging
VITE_DEBUG=false
