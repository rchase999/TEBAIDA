# DebateForge Environment Configuration
# Copy this file to .env and fill in your values

# ─── API Keys ─────────────────────────────────────────────────────
# At least one API key is required for AI debates

# Anthropic (Claude models)
DEBATEFORGE_ANTHROPIC_KEY=

# OpenAI (GPT-4, o1, o3 models)
DEBATEFORGE_OPENAI_KEY=

# Google (Gemini models)
DEBATEFORGE_GOOGLE_KEY=

# Mistral
DEBATEFORGE_MISTRAL_KEY=

# Groq
DEBATEFORGE_GROQ_KEY=

# ─── Local Model Endpoints ────────────────────────────────────────
# Configure endpoints for local AI model servers

# Ollama (default: http://localhost:11434)
DEBATEFORGE_OLLAMA_ENDPOINT=http://localhost:11434

# LM Studio (default: http://localhost:1234/v1)
DEBATEFORGE_LMSTUDIO_ENDPOINT=http://localhost:1234/v1

# ─── App Configuration ────────────────────────────────────────────

# Theme: light, dark, or system
DEBATEFORGE_THEME=system

# Enable streaming responses (true/false)
DEBATEFORGE_STREAMING=true

# Enable fallacy detection (true/false)
DEBATEFORGE_FALLACY_DETECTION=true

# Debate language (ISO 639-1 code: en, es, fr, de, etc.)
DEBATEFORGE_LANGUAGE=en
